PORT=5000
# Se estiver usando docker-compose local, use:
# MONGO_URI=mongodb://mongo:27017/linktrac-db
MONGO_URI=******seu_cluster.mongodb.net/link-prime-db
FRONTEND_URL=http://localhost:5173
JWT_SECRET=troque_para_uma_chave_secreta
JWT_EXPIRES_IN=8h
# Código opcional para proteger a criação inicial de clientes/usuários
REGISTER_SECRET=troque_para_codigo_de_registro
# Token opcional para autenticar dispositivos que enviam telemetria
DEVICE_API_TOKEN=troque_para_token_de_dispositivo
